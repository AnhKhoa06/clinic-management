@model ClinicManagement.DTOs.Auth.ChangePasswordDto
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="page-header">
    <div class="d-flex align-center gap-8">
        <a asp-controller="Settings" asp-action="Index" class="btn btn-outline" style="padding:8px 10px">
            <i class="ti ti-arrow-left"></i>
        </a>
        <h1 data-vi="Đổi mật khẩu" data-en="Change Password">Đổi mật khẩu</h1>
    </div>
</div>

<div class="card form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <i class="ti ti-alert-circle"></i>
            <div>
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@err.ErrorMessage</div> }
            </div>
        </div>
    }

    <form asp-action="ChangePassword" method="post">
        <div class="form-group">
            <label class="form-label">
                <span data-vi="Mật khẩu hiện tại" data-en="Current Password">Mật khẩu hiện tại</span>
                <span class="required">*</span>
            </label>
            <input asp-for="CurrentPassword" type="password" class="form-control"
                   placeholder="Nhập mật khẩu hiện tại" />
        </div>
        <div class="form-group">
            <label class="form-label">
                <span data-vi="Mật khẩu mới" data-en="New Password">Mật khẩu mới</span>
                <span class="required">*</span>
            </label>
            <input asp-for="NewPassword" type="password" class="form-control"
                   placeholder="Tối thiểu 6 ký tự" />
        </div>
        <div class="form-group">
            <label class="form-label">
                <span data-vi="Xác nhận mật khẩu mới" data-en="Confirm New Password">Xác nhận mật khẩu mới</span>
                <span class="required">*</span>
            </label>
            <input asp-for="ConfirmPassword" type="password" class="form-control"
                   placeholder="Nhập lại mật khẩu mới" />
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-check"></i>
                <span data-vi="Lưu" data-en="Save">Lưu</span>
            </button>
            <a asp-controller="Settings" asp-action="Index" class="btn btn-outline">
                <span data-vi="Huỷ" data-en="Cancel">Huỷ</span>
            </a>
        </div>
    </form>
</div>