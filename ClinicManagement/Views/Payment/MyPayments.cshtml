@model List<ClinicManagement.DTOs.Payment.PaymentResponseDto>
@{
    ViewData["Title"] = "Hóa đơn của tôi";
}

<div class="page-header">
    <h1 data-vi="Hóa đơn của tôi" data-en="My Invoices">Hóa đơn của tôi</h1>
</div>

<div class="card table-card">
    <table class="payment-table">
        <thead>
            <tr>
                <th data-vi="Mã hóa đơn" data-en="Invoice">Mã hóa đơn</th>
                <th data-vi="Bác sĩ" data-en="Doctor">Bác sĩ</th>
                <th data-vi="Ngày khám" data-en="Date">Ngày khám</th>
                <th data-vi="Số tiền" data-en="Amount">Số tiền</th>
                <th data-vi="Phương thức" data-en="Method">Phương thức</th>
                <th data-vi="Trạng thái" data-en="Status">Trạng thái</th>
                <th data-vi="Thao tác" data-en="Actions">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7">
                        <div class="empty-state">
                            <i class="ti ti-receipt-off"></i>
                            <p data-vi="Bạn chưa có hóa đơn nào." data-en="No invoices yet.">Bạn chưa có hóa đơn nào.</p>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td class="td-name">@item.InvoiceCode</td>
                    <td>@item.DoctorName</td>
                    <td>@item.SlotDate.ToString("dd/MM/yyyy")</td>
                    <td class="fw-500">@item.Amount.ToString("N0") ₫</td>
                    <td>
                        @if (item.Method == "Cash")
                        {
                            <span style="display:flex; align-items:center; gap:4px; font-size:12px;">
                                <i class="ti ti-cash" style="color:#10b981;"></i>
                                <span data-vi="Tiền mặt" data-en="Cash">Tiền mặt</span>
                            </span>
                        }
                        else
                        {
                            <span style="display:flex; align-items:center; gap:4px; font-size:12px;">
                                <i class="ti ti-building-bank" style="color:#3b82f6;"></i>
                                <span data-vi="Chuyển khoản" data-en="Bank Transfer">Chuyển khoản</span>
                            </span>
                        }
                    </td>
                    <td>
                        @if (item.Status == "Paid")
                        {
                            <span class="status status-active">
                                <span class="status-dot"></span>
                                <span data-vi="Đã thanh toán" data-en="Paid">Đã thanh toán</span>
                            </span>
                        }
                        else if (item.Method == "Cash")
                        {
                            <span class="status status-pending">
                                <span class="status-dot"></span>
                                <span data-vi="Chờ thu tiền mặt" data-en="Awaiting Cash">Chờ thu tiền mặt</span>
                            </span>
                        }
                        else
                        {
                            <span class="status status-pending">
                                <span class="status-dot"></span>
                                <span data-vi="Chưa thanh toán" data-en="Unpaid">Chưa thanh toán</span>
                            </span>
                        }
                    </td>
                    <td>
                        <div class="action-btns">
                            <a asp-action="Detail" asp-route-id="@item.Id" class="icon-btn" title="Xem chi tiết">
                                <i class="ti ti-eye"></i>
                            </a>
                            @if (item.Status == "Unpaid")
                            {
                                @if (item.Method == "Cash")
                                {
                                    <span style="font-size:12px; color:var(--text-secondary); white-space:nowrap;">
                                        <i class="ti ti-info-circle"></i>
                                        <span data-vi="Ra quầy thanh toán" data-en="Pay at counter">Ra quầy thanh toán</span>
                                    </span>
                                }
                                else
                                {
                                    <a asp-action="PayOnline" asp-route-id="@item.Id"
                                    class="btn btn-primary"
                                    style="font-size:12px; padding:5px 10px; height:auto;">
                                        <i class="ti ti-credit-card"></i>
                                        <span data-vi="Thanh toán" data-en="Pay Now">Thanh toán</span>
                                    </a>
                                }
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    setTimeout(function() {
        const params = new URLSearchParams(window.location.search);
        const toast = params.get('toast');
        const msg = params.get('msg');
        if (toast && msg) {
            showToast(toast, toast === 'success' ? 'Thành công' : 'Lỗi', msg);
            window.history.replaceState({}, '', '/Payment/MyPayments');
        }
    }, 100);
</script>
}