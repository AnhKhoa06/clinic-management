@model List<ClinicManagement.DTOs.Payment.PaymentResponseDto>
@{
    ViewData["Title"] = "Quản lý hóa đơn";
}

<div class="page-header">
    <h1 data-vi="Quản lý hóa đơn" data-en="Invoice Management">Quản lý hóa đơn</h1>
</div>

<div class="card table-card">
    <table class="payment-table">
        <thead>
            <tr>
                <th data-vi="Mã hóa đơn" data-en="Invoice">Mã hóa đơn</th>
                <th data-vi="Bệnh nhân" data-en="Patient">Bệnh nhân</th>
                <th data-vi="Bác sĩ" data-en="Doctor">Bác sĩ</th>
                <th data-vi="Ngày khám" data-en="Date">Ngày khám</th>
                <th data-vi="Số tiền" data-en="Amount">Số tiền</th>
                <th data-vi="Phương thức" data-en="Method">Phương thức</th>
                <th data-vi="Trạng thái" data-en="Status">Trạng thái</th>
                <th data-vi="Thao tác" data-en="Actions">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8">
                        <div class="empty-state">
                            <i class="ti ti-receipt-off"></i>
                            <p data-vi="Chưa có hóa đơn nào." data-en="No invoices yet.">Chưa có hóa đơn nào.</p>
                        </div>
                    </td>
                </tr>
            }

            @foreach (var item in Model)//duyệt từng hóa đơn
            {
                <tr>
                    <td class="td-name">@item.InvoiceCode</td>
                    <td>@item.PatientName</td>
                    <td class="td-muted">@item.DoctorName</td>
                    <td>@item.SlotDate.ToString("dd/MM/yyyy")</td>
                    <td class="fw-500">@item.Amount.ToString("N0") ₫</td>
                    <td>
                        @if (item.Status == "Unpaid" && User.IsInRole("Admin"))
                        {
                            <form asp-action="SetMethod" method="post" style="display:flex; align-items:center; gap:6px;">
                                <input type="hidden" name="id" value="@item.Id" />  @* gửi kèm id hóa đơn *@
                                <select name="method" class="form-control" style="font-size:12px; padding:4px 8px; height:auto;">
                                    <option value="Cash" selected="@(item.Method == "Cash")">Tiền mặt</option>
                                    <option value="BankTransfer" selected="@(item.Method == "BankTransfer")">Chuyển khoản</option>
                                </select>
                                <button type="submit" class="icon-btn" title="Lưu phương thức" style="color:var(--accent);">
                                    <i class="ti ti-device-floppy"></i>
                                </button>
                            </form>
                        }
                        else if (item.Method == "Cash")
                        {
                            <span style="display:flex; align-items:center; gap:4px; font-size:12px;">
                                <i class="ti ti-cash" style="color:#10b981;"></i>
                                <span data-vi="Tiền mặt" data-en="Cash">Tiền mặt</span>
                            </span>
                        }
                        else
                        {
                            <span style="display:flex; align-items:center; gap:4px; font-size:12px;">
                                <i class="ti ti-building-bank" style="color:#3b82f6;"></i>
                                <span data-vi="Chuyển khoản" data-en="Bank Transfer">Chuyển khoản</span>
                            </span>
                        }
                    </td>
                    <td>
                        @if (item.Status == "Paid")
                        {
                            <span class="status status-active">
                                <span class="status-dot"></span>
                                <span data-vi="Đã thanh toán" data-en="Paid">Đã thanh toán</span>
                            </span>
                        }
                        else
                        {
                            <span class="status status-pending">
                                <span class="status-dot"></span>
                                <span data-vi="Chưa thanh toán" data-en="Unpaid">Chưa thanh toán</span>
                            </span>
                        }
                    </td>
                    <td>
                        <div class="action-btns">
                            <a asp-action="Detail" asp-route-id="@item.Id" class="icon-btn" title="Xem chi tiết">
                                <i class="ti ti-eye"></i>
                            </a>
                            @if (item.Status == "Unpaid" && item.Method == "Cash" && User.IsInRole("Admin"))
                            {
                                <form asp-action="MarkPaid" asp-route-id="@item.Id" method="post" style="display:inline;"
                                    onsubmit="return confirm('Xác nhận đã thu tiền mặt hóa đơn @item.InvoiceCode?')">
                                    <button type="submit" class="icon-btn" title="Xác nhận đã thu tiền mặt"
                                            style="color:var(--success);">
                                        <i class="ti ti-cash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>