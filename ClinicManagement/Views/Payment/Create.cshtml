@model ClinicManagement.DTOs.Payment.PaymentCreateDto
@{
    ViewData["Title"] = "Tạo hóa đơn";
}

<div class="page-header">
    <div class="d-flex align-center gap-8">
        <a asp-controller="MedicalRecord" asp-action="Index" class="btn btn-outline" style="padding:8px 10px">
            <i class="ti ti-arrow-left"></i>
        </a>
        <h1 data-vi="Tạo hóa đơn" data-en="Create Invoice">Tạo hóa đơn</h1>
    </div>
</div>

<div class="card" style="max-width:480px; padding:28px;">
    <!-- Preview chi tiết tiền -->
    <div style="margin-bottom:24px; padding:16px; background:var(--bg-secondary); border-radius:10px; display:flex; flex-direction:column; gap:10px; font-size:13px;">
        <div style="display:flex; justify-content:space-between;">
            <span style="color:var(--text-secondary);">Phí khám</span>
            <span class="fw-500">@Convert.ToDecimal(ViewBag.ExaminationFee).ToString("N0") ₫</span>
        </div>
        <div style="display:flex; justify-content:space-between;">
            <span style="color:var(--text-secondary);">Phí thuốc</span>
            <span class="fw-500">@Convert.ToDecimal(ViewBag.MedicationFee).ToString("N0") ₫</span>
        </div>
        <div style="display:flex; justify-content:space-between; padding-top:10px; border-top:0.5px solid var(--card-border);">
            <span style="font-weight:600;">Tổng tiền</span>
            <span style="font-weight:700; color:var(--accent); font-size:16px;">@Convert.ToDecimal(ViewBag.TotalAmount).ToString("N0") ₫</span>
        </div>
    </div>

    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="AppointmentId" />

        <div style="margin-bottom:16px;">
            <label class="form-label" data-vi="Phương thức thanh toán" data-en="Payment Method">Phương thức thanh toán</label>
            <select asp-for="Method" class="form-control">
                <option value="Cash">Tiền mặt</option>
                <option value="BankTransfer">Chuyển khoản</option>
                <option value="Card">Thẻ</option>
            </select>
        </div>

        <div style="margin-bottom:24px;">
            <label class="form-label" data-vi="Ghi chú" data-en="Notes">Ghi chú</label>
            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Ghi chú thêm..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
            <i class="ti ti-receipt"></i>
            <span data-vi="Tạo hóa đơn" data-en="Create Invoice">Tạo hóa đơn</span>
        </button>
    </form>
</div>