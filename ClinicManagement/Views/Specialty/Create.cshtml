@model ClinicManagement.DTOs.Specialty.SpecialtyCreateDto
@{
    ViewData["Title"] = "Thêm chuyên khoa";
}

<div class="page-header">
    <div class="d-flex align-center gap-8">
        <a asp-action="Index" class="btn btn-outline" style="padding:8px 10px">
            <i class="ti ti-arrow-left"></i>
        </a>
        <h1 data-vi="Thêm chuyên khoa" data-en="Add Specialty">Thêm chuyên khoa</h1>
    </div>
</div>

<div class="card form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <i class="ti ti-alert-circle"></i>
            <div>
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@err.ErrorMessage</div> }
            </div>
        </div>
    }

    <form asp-action="Create" method="post">
        <div class="form-group">
            <label class="form-label">
                <span data-vi="Tên chuyên khoa" data-en="Specialty Name">Tên chuyên khoa</span>
                <span class="required">*</span>
            </label>
            <input asp-for="Name" class="form-control"
                   data-placeholder-vi="VD: Tim mạch, Da liễu..."
                   data-placeholder-en="E.g. Cardiology, Dermatology..."
                   placeholder="VD: Tim mạch, Da liễu..." />
        </div>
        <div class="form-group">
            <label class="form-label"
                   data-vi="Mô tả" data-en="Description">Mô tả</label>
            <textarea asp-for="Description" class="form-control"
                      data-placeholder-vi="Mô tả ngắn về chuyên khoa..."
                      data-placeholder-en="Short description of this specialty..."
                      placeholder="Mô tả ngắn về chuyên khoa..."></textarea>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-check"></i>
                <span data-vi="Lưu" data-en="Save">Lưu</span>
            </button>
            <a asp-action="Index" class="btn btn-outline">
                <span data-vi="Huỷ" data-en="Cancel">Huỷ</span>
            </a>
        </div>
    </form>
</div>