@model ClinicManagement.DTOs.Appointment.AppointmentCreateDto
@{
    ViewData["Title"] = "Đặt lịch khám";
    var doctors = ViewBag.Doctors as List<ClinicManagement.DTOs.Doctor.DoctorResponseDto> ?? new();
}

<div class="page-header">
    <div class="d-flex align-center gap-8">
        <a asp-action="MyAppointments" class="btn btn-outline" style="padding:8px 10px">
            <i class="ti ti-arrow-left"></i>
        </a>
        <h1 data-vi="Đặt lịch khám" data-en="Book Appointment">Đặt lịch khám</h1>
    </div>
</div>

<div class="card form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <i class="ti ti-alert-circle"></i>
            <div>
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@err.ErrorMessage</div> }
            </div>
        </div>
    }

    <form asp-action="Create" method="post" id="bookingForm">
        <div class="form-group">
            <label class="form-label">
                <span data-vi="Chọn bác sĩ" data-en="Select Doctor">Chọn bác sĩ</span>
                <span class="required">*</span>
            </label>
            <select asp-for="DoctorId" class="form-control" id="doctorSelect">
                <option value="">-- Chọn bác sĩ --</option>
                @foreach (var d in doctors)
                {
                    <option value="@d.Id">@d.FullName — @d.SpecialtyName</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">
                <span data-vi="Chọn ngày khám" data-en="Select Date">Chọn ngày khám</span>
                <span class="required">*</span>
            </label>
            <input type="date" id="dateSelect" class="form-control"
                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>

        <div class="form-group" id="slotGroup" style="display:none">
            <label class="form-label">
                <span data-vi="Chọn giờ khám" data-en="Select Time">Chọn giờ khám</span>
                <span class="required">*</span>
            </label>
            <div id="slotList" class="slot-grid"></div>
            <input type="hidden" asp-for="SlotId" id="slotId" />
        </div>

        <div class="form-group">
            <label class="form-label" data-vi="Lý do khám" data-en="Reason">Lý do khám</label>
            <textarea asp-for="Reason" class="form-control" rows="3"
                      placeholder="Mô tả triệu chứng hoặc lý do khám..."></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary" id="submitBtn" disabled>
                <i class="ti ti-calendar-check"></i>
                <span data-vi="Đặt lịch" data-en="Book">Đặt lịch</span>
            </button>
            <a asp-action="MyAppointments" class="btn btn-outline"
               data-vi="Huỷ" data-en="Cancel">Huỷ</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
const doctorSelect = document.getElementById('doctorSelect');
const dateSelect   = document.getElementById('dateSelect');
const slotGroup    = document.getElementById('slotGroup');
const slotList     = document.getElementById('slotList');
const slotIdInput  = document.getElementById('slotId');
const submitBtn    = document.getElementById('submitBtn');

async function loadSlots() {
    const doctorId = doctorSelect.value;
    const date     = dateSelect.value;
    if (!doctorId || !date) return;

    slotList.innerHTML = '<p style="color:var(--text-muted); font-size:13px;">Đang tải...</p>';
    slotGroup.style.display = 'block';
    slotIdInput.value = '';
    submitBtn.disabled = true;

    const res   = await fetch(`/Appointment/GetSlots?doctorId=${doctorId}&date=${date}`);
    const slots = await res.json();

    if (!slots.length) {
        slotList.innerHTML = '<p style="color:var(--text-muted); font-size:13px;">Không có slot trống trong ngày này.</p>';
        return;
    }

    slotList.innerHTML = slots.map(s => `
        <button type="button" class="slot-btn" data-id="${s.id}"
                onclick="selectSlot(${s.id}, this)">
            ${s.slotTime.substring(0,5)}
        </button>
    `).join('');
}

function selectSlot(id, el) {
    document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    slotIdInput.value = id;
    submitBtn.disabled = false;
}

doctorSelect.addEventListener('change', loadSlots);
dateSelect.addEventListener('change', loadSlots);
</script>
}