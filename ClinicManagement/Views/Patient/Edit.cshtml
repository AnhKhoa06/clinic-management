@model ClinicManagement.DTOs.Patient.PatientUpdateDto
@{
    ViewData["Title"] = "Chỉnh sửa bệnh nhân";
}

<div class="page-header">
    <div style="display:flex; align-items:center; gap:12px;">
        <a asp-action="Index" class="btn btn-outline">
            <i class="ti ti-arrow-left"></i>
        </a>
        <h1 data-vi="Chỉnh sửa thông tin" data-en="Edit Information">
            Chỉnh sửa — @ViewBag.FullName
        </h1>
    </div>
</div>

<div class="card" style="max-width:600px; padding:28px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <i class="ti ti-alert-circle"></i>
            <div>
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        </div>
    }

        <form asp-action="Edit" asp-route-id="@ViewBag.Id" method="post">
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" data-vi="Giới tính" data-en="Gender">Giới tính</label>
                <select asp-for="Gender" class="form-control">
                    <option value="">-- Chọn --</option>
                    <option value="Nam">Nam</option>
                    <option value="Nữ">Nữ</option>
                    <option value="Khác">Khác</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label" data-vi="Ngày sinh" data-en="Date of Birth">Ngày sinh</label>
                <input asp-for="DateOfBirth" type="date" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" data-vi="Địa chỉ" data-en="Address">Địa chỉ</label>
            <input asp-for="Address" class="form-control" placeholder="Số nhà, đường, quận/huyện, tỉnh/thành" />
        </div>

        <div class="form-group">
            <label class="form-label" data-vi="Liên hệ khẩn cấp" data-en="Emergency Contact">Liên hệ khẩn cấp</label>
            <input asp-for="EmergencyContact" class="form-control" placeholder="Tên người thân — Số điện thoại" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-check"></i>
                <span data-vi="Lưu" data-en="Save">Lưu</span>
            </button>
            <a asp-action="Index" class="btn btn-outline"
               data-vi="Huỷ" data-en="Cancel">Huỷ</a>
        </div>
    </form>
</div>