@using ClinicManagement.Services
@using ClinicManagement.Models
@using System.Security.Claims
@inject PaymentService PaymentService
@inject AppointmentService AppointmentService
@inject DoctorService DoctorService
@inject NotificationService NotificationService

@{
    int unpaidCount = User.IsInRole("Admin") ? await PaymentService.GetUnpaidCountAsync() : 0;
    //gọi GetUnpaidCountAsync() để đếm số hóa đơn chưa thanh toán, dùng cho badge đỏ ở mục Hóa đơn.

    int pendingCount = 0; //đếm số lịch hẹn đang chờ xác nhận (Pending), dùng cho badge ở mục jịch hẹn
    if (User.IsInRole("Admin")) //Nếu là Admin thì đếm toàn bộ hệ thống
    {
        pendingCount = await AppointmentService.GetPendingCountAsync();
    }
    else if (User.IsInRole("Doctor")) //Nếu là Doctor thì lấy userId từ claim, 
    //tìm ra doctorId tương ứng, rồi chỉ đếm lịch hẹn của bác sĩ đó thôi
    {
        var userId = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "0");
        var doctor = await DoctorService.GetByUserIdAsync(userId);
        if (doctor != null)
            pendingCount = await AppointmentService.GetPendingCountByDoctorAsync(doctor.Id);
    }

    int patientUnpaidCount = 0;
    if (User.IsInRole("Patient"))
    {
        var userId = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "0");//Lấy userId 
        //từ claim (tức là id của người đang đăng nhập)
        var patientPayments = await PaymentService.GetByPatientAsync(userId);
        //Gọi GetByPatientAsync(userId) lấy toàn bộ hóa đơn của patient đó
        patientUnpaidCount = patientPayments.Count(p => p.Status == "Unpaid");
        //Đếm xem có bao nhiêu cái Status == "Unpaid" → gán vào patientUnpaidCount
    }

    int notificationUnreadCount = 0;
    var initialNotifications = new List<Notification>();
    if (User.Identity?.IsAuthenticated == true)
    {
        var userId = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "0");
        var role = User.IsInRole("Admin") ? "Admin" : User.IsInRole("Doctor") ? "Doctor" : "Patient";
        notificationUnreadCount = await NotificationService.CountUnreadAsync(userId, role);
        initialNotifications = await NotificationService.GetForUserAsync(userId, role);
    }
}

<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Phòng Khám</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@2.44.0/tabler-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/app.css" />
</head>
<body>
<div class="app-wrapper">

    <!-- ========== SIDEBAR ========== -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-row">
                <div class="logo-icon-wrap">
                    <i class="ti ti-building-hospital"></i>
                </div>
                <div>
                    <div class="logo-text" data-vi="Phòng Khám" data-en="Clinic">Phòng Khám</div>
                    <div class="logo-sub" data-vi="Hệ thống quản lý" data-en="Management System">Hệ thống quản lý</div>
                </div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <!-- Tổng quan -->
            <div class="nav-section">
                <span class="nav-section-label" data-vi="Tổng quan" data-en="Overview">Tổng quan</span>
                <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="ti ti-home"></i>
                    <span data-vi="Trang chủ" data-en="Dashboard">Trang chủ</span>
                </a>
            </div>
            
            @if (User.IsInRole("Admin"))
            {
                <!-- Quản lý -->
                <div class="nav-section">
                    <span class="nav-section-label" data-vi="Quản lý" data-en="Management">Quản lý</span>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Specialty" ? "active" : "")"
                       asp-controller="Specialty" asp-action="Index">
                        <i class="ti ti-grid-dots"></i>
                        <span data-vi="Chuyên khoa" data-en="Specialties">Chuyên khoa</span>
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctor" ? "active" : "")"
                       asp-controller="Doctor" asp-action="Index">
                        <i class="ti ti-stethoscope"></i>
                        <span data-vi="Bác sĩ" data-en="Doctors">Bác sĩ</span>
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" ? "active" : "")"
                       asp-controller="Patient" asp-action="Index">
                        <i class="ti ti-users"></i>
                        <span data-vi="Bệnh nhân" data-en="Patients">Bệnh nhân</span>
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Medication" ? "active" : "")"
                       asp-controller="Medication" asp-action="Index">
                        <i class="ti ti-pill"></i>
                        <span data-vi="Thuốc" data-en="Medications">Thuốc</span>
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "active" : "")"
                        asp-controller="Payment" asp-action="Index"
                        style="justify-content: space-between;">
                        <div style="display:flex; align-items:center; gap:10px;">
                            <i class="ti ti-receipt"></i>
                            <span data-vi="Hóa đơn" data-en="Invoices">Hóa đơn</span>
                        </div>
                        @if (unpaidCount > 0)
                        {
                            <span style="background:#306ce4; color:#fff; font-size:11px; font-weight:600;
                                        min-width:18px; height:18px; border-radius:999px;
                                        display:flex; align-items:center; justify-content:center; padding:0 5px;">
                                @unpaidCount
                            </span>
                        }
                    </a>
                </div>
            }

            @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
            {
                <!-- Lịch khám -->
                <div class="nav-section">
                    <span class="nav-section-label" data-vi="Lịch khám" data-en="Schedule">Lịch khám</span>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointment" ? "active" : "")"
                       asp-controller="Appointment" asp-action="Index" style="justify-content: space-between;">
                        <div style="display:flex; align-items:center; gap:10px;">
                            <i class="ti ti-calendar-check"></i>
                            <span data-vi="Lịch hẹn" data-en="Appointments">Lịch hẹn</span>
                        </div>
                        @if (pendingCount > 0)
                        {
                            <span style="background:#306ce4; color:#fff; font-size:11px; font-weight:600;
                                        min-width:18px; height:18px; border-radius:999px;
                                        display:flex; align-items:center; justify-content:center; padding:0 5px;">
                                @pendingCount
                            </span>
                        }
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "WorkingSchedule" ? "active" : "")"
                        asp-controller="WorkingSchedule" asp-action="Index">
                        <i class="ti ti-clock"></i>
                        <span data-vi="Lịch làm việc" data-en="Working Schedule">Lịch làm việc</span>
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "MedicalRecord" ? "active" : "")"
                    asp-controller="MedicalRecord" asp-action="Index">
                        <i class="ti ti-clipboard-text"></i>
                        <span data-vi="Hồ sơ bệnh án" data-en="Medical Records">Hồ sơ bệnh án</span>
                    </a>
                    @if (User.IsInRole("Doctor"))
                    {
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "active" : "")"
                        asp-controller="Payment" asp-action="Index">
                            <i class="ti ti-receipt"></i>
                            <span data-vi="Hóa đơn" data-en="Invoices">Hóa đơn</span>
                        </a>
                    }
                </div>
            }

            @if (User.IsInRole("Patient"))
            {
                <div class="nav-section">
                    <span class="nav-section-label" data-vi="Của tôi" data-en="My Account">Của tôi</span>
                    <a class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "MyAppointments" ? "active" : "")"
                       asp-controller="Appointment" asp-action="MyAppointments">
                        <i class="ti ti-calendar-check"></i>
                        <span data-vi="Lịch hẹn của tôi" data-en="My Appointments">Lịch hẹn của tôi</span>
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctor" && ViewContext.RouteData.Values["action"]?.ToString() == "Browse" ? "active" : "")"
                        asp-controller="Doctor" asp-action="Browse">
                        <i class="ti ti-stethoscope"></i>
                        <span data-vi="Tìm bác sĩ" data-en="Find Doctor">Tìm bác sĩ</span>
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "MyRecords" ? "active" : "")"
                       asp-controller="MedicalRecord" asp-action="MyRecords">
                        <i class="ti ti-clipboard-text"></i>
                        <span data-vi="Hồ sơ bệnh án" data-en="Medical Records">Hồ sơ bệnh án</span>
                    </a>
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" && ViewContext.RouteData.Values["action"]?.ToString() == "MyPayments" ? "active" : "")"
                        asp-controller="Payment" asp-action="MyPayments"
                        style="justify-content: space-between;">
                        <div style="display:flex; align-items:center; gap:10px;">
                            <i class="ti ti-receipt"></i>
                            <span data-vi="Hóa đơn của tôi" data-en="My Invoices">Hóa đơn của tôi</span>
                        </div>
                        @if (patientUnpaidCount > 0)
                        {
                            <span style="background:#306ce4; color:#fff; font-size:11px; font-weight:600;
                                        min-width:18px; height:18px; border-radius:999px;
                                        display:flex; align-items:center; justify-content:center; padding:0 5px;">
                                @patientUnpaidCount
                            </span>
                        }
                    </a>
                </div>
            }

            <!-- Cài đặt — luôn hiển thị -->
            <div class="nav-section">
                <span class="nav-section-label" data-vi="Hệ thống" data-en="System">Hệ thống</span>
                <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")"
                   asp-controller="Settings" asp-action="Index">
                    <i class="ti ti-settings"></i>
                    <span data-vi="Cài đặt" data-en="Settings">Cài đặt</span>
                </a>
            </div>
        </nav>

        <!-- User + Logout -->
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar">
                    @(User.Identity?.Name?.Substring(0, Math.Min(2, User.Identity?.Name?.Length ?? 0)).ToUpper())
                </div>
                <div>
                    <div class="user-name">@User.Identity?.Name</div>
                    <div class="user-role">
                        @if (User.IsInRole("Admin")) { <span data-vi="Quản trị viên" data-en="Administrator">Quản trị viên</span> }
                        else if (User.IsInRole("Doctor")) { <span data-vi="Bác sĩ" data-en="Doctor">Bác sĩ</span> }
                        else { <span data-vi="Bệnh nhân" data-en="Patient">Bệnh nhân</span> }
                    </div>
                </div>
            </div>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button class="btn-logout" type="button" onclick="showLogout()">
                    <i class="ti ti-logout"></i>
                    <span>Đăng xuất</span>
                </button>
            </form>
        </div>
    </aside>

    <!-- ========== MAIN ========== -->
    <div class="main-content">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger-btn" id="hamburgerBtn">
                    <i class="ti ti-menu-2"></i>
                </button>
                <span class="topbar-title">@(ViewData["Title"] ?? "Trang chủ")</span>
            </div>
            <div class="topbar-right">
                <!-- Role badge -->
                <span class="badge-role">
                    @if (User.IsInRole("Admin")) { <span data-vi="Quản trị viên" data-en="Admin">Quản trị viên</span> }
                    else if (User.IsInRole("Doctor")) { <span data-vi="Bác sĩ" data-en="Doctor">Bác sĩ</span> }
                    else { <span data-vi="Bệnh nhân" data-en="Patient">Bệnh nhân</span> }
                </span>

                <!-- Language toggle -->
                <button class="lang-pill" id="langToggle" title="Switch language">
                    <i class="ti ti-language lang-icon"></i>
                    <span class="lang-code">VI</span>
                </button>

                <!-- Notification -->
                <div class="notif-root">
                    <button class="notif-btn" id="notifToggle" aria-label="Notifications">
                        <i class="ti ti-bell"></i>
                        <span class="notif-badge" id="notifBadge" style="@(notificationUnreadCount > 0 ? "display:inline-flex;" : "display:none;")">@notificationUnreadCount</span>
                    </button>

                    <div class="notif-panel" id="notifPanel" aria-hidden="true">
                        <div class="notif-panel-header">
                            <strong>Thông báo</strong>
                            <button class="notif-close" id="notifClose"><i class="ti ti-x"></i></button>
                        </div>
                        <div class="notif-list" id="notifList">
                        </div>
                        <div class="notif-footer">
                            <a href="/" id="notifViewAll">Xem tất cả</a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Alerts -->
        <div class="page-body">
            <!-- Toast container -->
                <div class="toast-container" id="toastContainer"></div>

            @RenderBody()
        </div>
    </div>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
</div>

<script>
// ── LANGUAGE TOGGLE ──────────────────────────────────────────
const LANG_KEY = 'clinic_lang';
const langToggle = document.getElementById('langToggle');
const langCode = langToggle.querySelector('.lang-code');

function applyLang(lang) {
    document.querySelectorAll('[data-vi]').forEach(el => {
        el.textContent = lang === 'en' ? el.dataset.en : el.dataset.vi;
    });
    langCode.textContent = lang === 'en' ? 'EN' : 'VI';
    langToggle.title = lang === 'en' ? 'Switch to Vietnamese' : 'Switch to English';
    localStorage.setItem(LANG_KEY, lang);
}

langToggle.addEventListener('click', () => {
    const current = localStorage.getItem(LANG_KEY) || 'vi';
    applyLang(current === 'vi' ? 'en' : 'vi');
});

// Init lang on load
applyLang(localStorage.getItem(LANG_KEY) || 'vi');

// ── THEME ────────────────────────────────────────────────────
const THEME_KEY = 'clinic_theme';

function applyTheme(theme) {
    const html = document.documentElement;
    if (theme === 'system') {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        html.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
    } else {
        html.setAttribute('data-theme', theme);
    }
    localStorage.setItem(THEME_KEY, theme);
    // sync theme cards nếu đang ở trang settings
    document.querySelectorAll('.theme-card').forEach(c => {
        c.classList.toggle('active', c.dataset.theme === theme);
    });
}

// Init theme on load
applyTheme(localStorage.getItem(THEME_KEY) || 'light');

// Lắng nghe system preference thay đổi
window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if ((localStorage.getItem(THEME_KEY) || 'light') === 'system') applyTheme('system');
});

// Expose globally để Settings page dùng
window.setTheme = applyTheme;

// ── AUTO DISMISS ALERTS ──────────────────────────────────────
['alert-success','alert-error'].forEach(id => {
    const el = document.getElementById(id);
    if (el) setTimeout(() => el.remove(), 4000);
});

// ── HAMBURGER SIDEBAR ────────────────────────
const hamburgerBtn = document.getElementById('hamburgerBtn');
const sidebarOverlay = document.getElementById('sidebarOverlay');
const sidebar = document.querySelector('.sidebar');

hamburgerBtn?.addEventListener('click', () => {
    sidebar.classList.toggle('open');
    sidebarOverlay.classList.toggle('active');
});

sidebarOverlay?.addEventListener('click', () => {
    sidebar.classList.remove('open');
    sidebarOverlay.classList.remove('active');
});
</script>

@await RenderSectionAsync("Scripts", required: false)

<!-- Logout Dialog -->
<div id="logoutOverlay" class="logout-overlay">
    <div class="logout-dialog">
        <div class="logout-icon">
            <i class="ti ti-logout"></i>
        </div>
        <div class="logout-title">Xác nhận đăng xuất</div>
        <div class="logout-desc">Bạn có chắc chắn muốn đăng xuất không?</div>
        <div class="logout-actions">
            <button class="logout-btn-cancel" onclick="closeLogout()">Huỷ</button>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit" class="logout-btn-confirm">Đồng ý</button>
            </form>
        </div>
    </div>
</div>

<script>
    function showLogout() {
        const overlay = document.getElementById('logoutOverlay');
        overlay.style.display = 'flex';
        // Delay nhỏ để trigger transition
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                overlay.classList.add('active');
            });
        });
    }

    function closeLogout() {
        const overlay = document.getElementById('logoutOverlay');
        overlay.classList.remove('active');
        setTimeout(() => overlay.style.display = 'none', 300);
    }

    document.getElementById('logoutOverlay').addEventListener('click', function(e) {
        if (e.target === this) closeLogout();
    });
    

    // ── TOAST ────────────────────────────────────────────
    function showToast(type, title, msg) {
        const container = document.getElementById('toastContainer');
        const icon = type === 'success' ? 'ti-circle-check' : 'ti-alert-circle';

        const toast = document.createElement('div');
        toast.className = `toast ${type}`;
        toast.innerHTML = `
            <i class="ti ${icon} toast-icon"></i>
            <div class="toast-body">
                <div class="toast-title">${title}</div>
                <div class="toast-msg">${msg}</div>
            </div>
            <button class="toast-close" onclick="removeToast(this.parentElement)">
                <i class="ti ti-x"></i>
            </button>
        `;

        container.appendChild(toast);
        setTimeout(() => removeToast(toast), 2000);
    }

    function removeToast(toast) {
        if (!toast) return;
        toast.style.animation = 'toast-out 0.3s ease forwards';
        setTimeout(() => toast.remove(), 300);
    }

    // Hiện toast từ TempData
    @if (TempData["Success"] != null)
    {
        <text>showToast('success', 'Thành công', '@TempData["Success"]');</text>
    }
    @if (TempData["Error"] != null)
    {
        <text>showToast('error', 'Lỗi', '@TempData["Error"]');</text>
    }

    // ── NOTIFICATIONS (AJAX) ───────────────────────────
    const notifToggle = document.getElementById('notifToggle');
    const notifPanel = document.getElementById('notifPanel');
    const notifList = document.getElementById('notifList');
    const notifBadge = document.getElementById('notifBadge');

    const initialNotifData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(initialNotifications.Select(n => new {
        id = n.Id,
        title = n.Title,
        message = n.Message,
        isRead = n.IsRead,
        createdAt = n.CreatedAt,
        link = n.Link
    })));

    let notifData = Array.isArray(initialNotifData) ? initialNotifData : [];

    async function fetchNotifications() {
        try {
            const res = await fetch('/api/notifications', { credentials: 'same-origin' });
            if (!res.ok) return;
            const data = await res.json();
            notifData = data;
            renderNotifications();
        } catch (e) {
            console.error('Failed to fetch notifications', e);
        }
    }

    function renderNotifications() {
        notifList.innerHTML = '';
        if (!notifData || notifData.length === 0) {
            notifList.innerHTML = '<div class="notif-empty">Không có thông báo</div>';
            notifBadge.style.display = 'none';
            return;
        }

        let unread = 0;
        notifData.forEach(n => {
            if (!n.isRead) unread++;
            const item = document.createElement('div');
            item.className = 'notif-item' + (n.isRead ? ' read' : ' unread');
            item.innerHTML = `
                <div class="notif-item-body">
                    <div class="notif-item-title">${escapeHtml(n.title)}</div>
                    <div class="notif-item-msg">${escapeHtml(n.message)}</div>
                </div>
                <div class="notif-item-meta">${timeAgo(new Date(n.createdAt))}</div>
            `;
            item.addEventListener('click', () => onNotifClick(n));
            notifList.appendChild(item);
        });

        if (unread > 0) {
            notifBadge.textContent = unread > 99 ? '99+' : String(unread);
            notifBadge.style.display = 'inline-flex';
        } else {
            notifBadge.style.display = 'none';
        }
    }

    function escapeHtml(s) { return (s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;','\'':"&#39;"})[c]); }

    async function onNotifClick(n) {
        try {
            await fetch(`/api/notifications/mark-read/${n.id}`, { method: 'POST' });
        } catch (e) { console.warn(e); }
        // optional navigation
        if (n.link) location.href = n.link;
        fetchNotifications();
    }

    function timeAgo(date) {
        const utcDate = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
        const seconds = Math.floor((new Date() - utcDate) / 1000);
        const intervals = [[60,'giây'],[60,'phút'],[24,'giờ'],[7,'ngày'],[4.34524,'tuần'],[12,'tháng'],[Number.POSITIVE_INFINITY,'năm']];
        let unit = 'giây';
        let value = seconds;
        for (let i=0, s=seconds; i<intervals.length; i++){
            const [div,name] = intervals[i];
            if (s < div) { unit = name; value = Math.floor(s); break; }
            s = s / div;
        }
        return value + ' ' + unit + ' trước';
    }

    notifToggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = notifPanel.classList.toggle('open');
        notifPanel.setAttribute('aria-hidden', !open);
        if (open) fetchNotifications();
    });

    document.getElementById('notifClose')?.addEventListener('click', () => {
        notifPanel.classList.remove('open');
        notifPanel.setAttribute('aria-hidden', 'true');
    });

    document.addEventListener('click', (e) => {
        if (!notifPanel.contains(e.target) && e.target !== notifToggle) {
            notifPanel.classList.remove('open');
            notifPanel.setAttribute('aria-hidden', 'true');
        }
    });

    // initial render from server data, then refresh from API
    renderNotifications();
    fetchNotifications();
    // poll every 30s
    setInterval(fetchNotifications, 30000);
</script>
</body>
</html>