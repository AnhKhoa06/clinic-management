@model ClinicManagement.DTOs.Doctor.DoctorUpdateDto
@{
    ViewData["Title"] = "Sửa bác sĩ";
}

<div class="page-header">
    <div style="display:flex; align-items:center; gap:12px;">
        <a asp-action="Index" class="btn btn-outline">
            <i class="ti ti-arrow-left"></i>
        </a>
        <h1 data-vi="Sửa thông tin bác sĩ" data-en="Edit Doctor">Sửa thông tin bác sĩ</h1>
    </div>
</div>

<div class="card" style="max-width:600px; padding:28px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-error">
            <i class="ti ti-alert-circle"></i>
            <div>
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        </div>
    }

    <form asp-action="Edit" asp-route-id="@ViewBag.Id" method="post">
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" data-vi="Chuyên khoa" data-en="Specialty">Chuyên khoa <span class="required">*</span></label>
                <select asp-for="SpecialtyId" class="form-control">
                    <option value="">-- Chọn chuyên khoa --</option>
                    @foreach (var s in ViewBag.Specialties as List<ClinicManagement.DTOs.Specialty.SpecialtyResponseDto> ?? new())
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label" data-vi="Số giấy phép" data-en="License Number">Số giấy phép <span class="required">*</span></label>
                <input asp-for="LicenseNumber" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Bio</label>
            <textarea asp-for="Bio" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-group">
            <label class="form-label">Avatar URL</label>
            <input asp-for="AvatarUrl" class="form-control" placeholder="https://..." />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-check"></i>
                <span data-vi="Cập nhật" data-en="Update">Cập nhật</span>
            </button>
            <a asp-action="Index" class="btn btn-outline"
               data-vi="Huỷ" data-en="Cancel">Huỷ</a>
        </div>
    </form>
</div>