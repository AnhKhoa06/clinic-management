@model ClinicManagement.DTOs.Doctor.DoctorCreateWithAccountDto
@{
    ViewData["Title"] = "Thêm bác sĩ";
}

<div class="page-header">
    <div style="display:flex; align-items:center; gap:12px;">
        <a asp-action="Index" class="btn btn-outline">
            <i class="ti ti-arrow-left"></i>
        </a>
        <h1 data-vi="Thêm bác sĩ" data-en="Add Doctor">Thêm bác sĩ</h1>
    </div>
</div>

<div class="card" style="max-width:600px; padding:28px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-error">
            <i class="ti ti-alert-circle"></i>
            <div>
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        </div>
    }

    <form asp-action="Create" method="post">
        <div class="form-section-title">
            <i class="ti ti-user"></i>
            <span data-vi="Thông tin tài khoản" data-en="Account Information">Thông tin tài khoản</span>
        </div>

        <div class="form-group">
            <label class="form-label" data-vi="Họ và tên" data-en="Full Name">Họ và tên <span class="required">*</span></label>
            <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Email <span class="required">*</span></label>
                <input asp-for="Email" type="email" class="form-control" placeholder="doctor@gmail.com" />
            </div>
            <div class="form-group">
                <label class="form-label" data-vi="Số điện thoại" data-en="Phone">Số điện thoại</label>
                <input asp-for="Phone" class="form-control" placeholder="0901 234 567" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" data-vi="Mật khẩu" data-en="Password">Mật khẩu <span class="required">*</span></label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" />
        </div>

        <div class="form-section-title" style="margin-top:24px;">
            <i class="ti ti-stethoscope"></i>
            <span data-vi="Thông tin chuyên môn" data-en="Professional Information">Thông tin chuyên môn</span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label" data-vi="Chuyên khoa" data-en="Specialty">Chuyên khoa <span class="required">*</span></label>
                <select asp-for="SpecialtyId" class="form-control">
                    <option value="">-- Chọn chuyên khoa --</option>
                    @foreach (var s in ViewBag.Specialties as List<ClinicManagement.DTOs.Specialty.SpecialtyResponseDto> ?? new())
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label" data-vi="Số giấy phép" data-en="License Number">Số giấy phép <span class="required">*</span></label>
                <input asp-for="LicenseNumber" class="form-control" placeholder="VD: GP-12345" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Bio</label>
            <textarea asp-for="Bio" class="form-control" rows="3"
                      placeholder="Mô tả ngắn về bác sĩ..."></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-check"></i>
                <span data-vi="Lưu" data-en="Save">Lưu</span>
            </button>
            <a asp-action="Index" class="btn btn-outline"
               data-vi="Huỷ" data-en="Cancel">Huỷ</a>
        </div>
    </form>
</div>